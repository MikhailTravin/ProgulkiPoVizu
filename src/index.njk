                    </div>
                </div>
            </section>

            <section class="block-offer section">
                <img loading="lazy" src="img/backgrounds/offers-sunrise-no-yachts.webp" alt="" class="block-offer__bg1">
                <div class="container">
                    <div class="block-offer__content">
                        <div class="block-offer__heading">
                            <h2 class="title2">
                                Мы предлагаем
                            </h2>
                            <p>
                                Выберите время и отправляйтесь в своё путешествие
                                по живописным местам водохранилища.
                            </p>
                        </div>
                        <div class="block-offer__body">
                            <div class="block-offer__column">
                                <div class="block-offer__time"><span>1</span> час</div>
                                <p>
                                    Маршрут проходит мимо
                                    «Малого Конного» острова
                                    и полуострова «Баран» до
                                    турбазы «Куба» — отлично для
                                    первого знакомства с яхтингом.
                                </p>
                                <a href="./" class="btn btn-border">Интересует</a>
                            </div>
                            <div class="block-offer__column column-big">
                                <div class="block-offer__time"><span>3</span> часа</div>
                                <p>
                                    Экспедиция по уральскому морю.
                                    Вы увидите все живописные места
                                    водохранилища — маршрут для
                                    настоящих ценителей уральской природы.
                                </p>
                                <div class="block-offer__badge">
                                    <img loading="lazy" src="img/icons/star.svg" alt="">
                                    самый крутой тариф
                                </div>
                                <a href="./" class="btn btn-border">Интересует</a>
                            </div>
                            <div class="block-offer__column">
                                <div class="block-offer__time"><span>2</span> часа</div>
                                <p>
                                    Маршрут проходит мимо «Малого
                                    Конного» острова, турбазы «Куба»,
                                    полуостровов «Баран» и «Большой»,
                                    островов «Шабур» и «Плоский» —
                                    идеальный баланс продолжительности
                                    и впечатлений.
                                </p>
                                <a href="./" class="btn btn-border">Интересует</a>
                            </div>
                        </div>
                    </div>
                    <div class="block-offer__image1">
                        <img loading="lazy" src="img/yachts/yacht-left.webp" alt="">
                    </div>
                    <div class="block-offer__image2">
                        <img loading="lazy" src="img/yachts/yacht-center.webp" alt="">
                    </div>
                    <div class="block-offer__image3">
                        <img loading="lazy" src="img/yachts/yacht-right.webp" alt="">
                    </div>
                </div>
            </section>

