            <section class="block-intro section">
                <!--<img src="img/promo.gif" alt="" class="block-intro__bg">-->
                <div class="container">
                    <div class="block-intro__content">
                        <h1 class="title1">
                            Организуем<br>
                            лучший <span>отдых на яхте</span><br>
                            не выезжая из<br>
                            Екатеринбурга
                        </h1>
                        <div class="block-intro__line"></div>
                        <a href="./" class="btn btn-big">
                            <img src="img/icons/anchor.svg" alt="">
